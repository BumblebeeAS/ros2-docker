BUILD_IMAGE_FLAG=1

# These parameters are only relevant if BUILD_IMAGE_FLAG=1
# CuDNN is in the Isaac ROS x86_64 image but not in the JP6 image for some reason.
CONFIG_IMAGE_KEY=ros2_humble.trt.ultralytics_cuda.micro_xrce_dds_agent.ccache.drone_sim
CONFIG_DOCKER_SEARCH_DIRS=(
    "$HOME/workspaces/ros2-docker/dockerfiles/common"
    "$HOME/workspaces/ros2-docker/dockerfiles/isaac_ros_x64"
)

# Runs built image if BUILD_IMAGE_FLAG=0
BUILT_IMAGE=isaac_ros_dev-aarch64:latest

# Note that env variables like $HOME cannot be unpacked here
MOUNT_DIRS=(
    "$HOME/workspaces/isaac_ros-dev:/workspaces/isaac_ros-dev"
    "$HOME/.cache/ccache:/home/admin/.cache/ccache"
    "$HOME/.cache/torch:/home/admin/.cache/torch" 
    "$HOME/.cache/matplotlib:/home/admin/.cache/matplotlib"
)
WORKDIR=/workspaces/isaac_ros-dev
DOCKER_CONTEXT_DIR=$HOME/workspaces/ros2-docker/
